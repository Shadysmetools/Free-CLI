flowchart TB
    %% Input Layer
    subgraph INPUT["🎤 Input Layer"]
        direction TB
        I1["💬 Chat Input Box\n(bordered UI)"]
        I2["/ Slash Commands\n(/help /plan /review)"]
        I3["⚙️ CLI Flags\n(--provider --model --voice)"]
        I4["🎙️ Voice Input\n(Whisper)"]
    end

    %% Core Engine
    subgraph CORE["⚙️ Core Engine"]
        direction TB
        C1["🔄 Agent Loop\n(runAgent)"]
        C2["💬 Conversation Manager"]
        C3["🧠 Skill Detector"]
        C4["📝 Memory System\n(MEMORY.md)"]
        C5["📊 Token Tracker"]
    end

    %% AI Providers
    subgraph PROVIDERS["🤖 AI Providers (auto-fallback)"]
        direction LR
        P1["🟢 OpenRouter\n(default)"]
        P2["🦙 Ollama\n(local)"]
        P3["⚡ Groq\n(free tier)"]
        P4["🔵 Google Gemini"]
        P5["🟠 Anthropic Claude"]
        P6["🟣 OpenAI GPT"]
    end

    %% Tool Registry
    subgraph TOOLS["🛠️ Tool Registry (18 tools)"]
        direction TB
        T1["📁 File\nread · write · edit · search · list"]
        T2["💻 Shell\nrun_command"]
        T3["🔀 Git\nstatus · diff · commit · log"]
        T4["🧠 Memory\nsave · search"]
        T5["📤 Output\nPDF · Excel · Diagram · Image"]
    end

    %% Sub-Agent System
    subgraph SUBAGENTS["🤝 Sub-Agent System"]
        direction TB
        S1["🎯 Orchestrator"]
        S2["📋 Planner (/plan)"]
        S3["👥 Roles\narchitect · coder · reviewer\ntester · debugger · documenter"]
    end

    %% Features
    subgraph FEATURES["✨ Features"]
        direction TB
        F1["🌍 Persona System\n(10 languages/dialects)"]
        F2["👤 User Profile + History"]
        F3["🔍 Agentic RAG + Reranking"]
        F4["🔌 MCP Protocol Client"]
        F5["🧩 Plugin System"]
        F6["🌐 REST API Server"]
    end

    %% Output Layer
    subgraph OUTPUT["📤 Output Layer"]
        direction TB
        O1["🖥️ Terminal UI\n(chalk, bordered boxes)"]
        O2["💻 Code Boxes\n(syntax highlighted)"]
        O3["📄 PDF Generation\n(styled)"]
        O4["📊 Excel Generation\n(formatted)"]
        O5["📈 Mermaid Diagrams"]
    end

    %% Connections
    INPUT --> CORE
    CORE --> PROVIDERS
    CORE --> TOOLS
    CORE --> SUBAGENTS
    CORE --> FEATURES
    PROVIDERS --> CORE
    TOOLS --> CORE
    SUBAGENTS --> CORE
    CORE --> OUTPUT

    %% Styling
