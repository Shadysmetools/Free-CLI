    classDef coreStyle fill:#2E7D32,stroke:#1B5E20,color:#ffffff,rx:8
    classDef providerStyle fill:#E65100,stroke:#BF360C,color:#ffffff,rx:8
    classDef toolStyle fill:#6A1B9A,stroke:#4A148C,color:#ffffff,rx:8
    classDef subagentStyle fill:#B71C1C,stroke:#7F0000,color:#ffffff,rx:8
    classDef featureStyle fill:#00695C,stroke:#004D40,color:#ffffff,rx:8
    classDef outputStyle fill:#1565C0,stroke:#0D47A1,color:#ffffff,rx:8

    class I1,I2,I3,I4 inputStyle
    class C1,C2,C3,C4,C5 coreStyle
    class P1,P2,P3,P4,P5,P6 providerStyle
    class T1,T2,T3,T4,T5 toolStyle
    class S1,S2,S3 subagentStyle
    class F1,F2,F3,F4,F5,F6 featureStyle
    class O1,O2,O3,O4,O5 outputStyle

    style INPUT fill:#0D2137,stroke:#1565C0,color:#90CAF9
    style CORE fill:#0A2010,stroke:#2E7D32,color:#A5D6A7
    style PROVIDERS fill:#1A0E00,stroke:#E65100,color:#FFCC80
    style TOOLS fill:#160820,stroke:#6A1B9A,color:#CE93D8
    style SUBAGENTS fill:#1A0000,stroke:#B71C1C,color:#EF9A9A
