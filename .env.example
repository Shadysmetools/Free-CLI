# Copy to .env and fill in your keys
# Or set these as environment variables

# Groq (free tier) - https://console.groq.com
GROQ_API_KEY=

# Google Gemini (free tier) - https://aistudio.google.com
GOOGLE_API_KEY=

# OpenRouter (free models) - https://openrouter.ai
OPENROUTER_API_KEY=

# Anthropic (BYOK) - https://console.anthropic.com
ANTHROPIC_API_KEY=

# OpenAI (BYOK) - https://platform.openai.com
OPENAI_API_KEY=

# Ollama (local, default: http://localhost:11434)
# OLLAMA_BASE_URL=http://localhost:11434
