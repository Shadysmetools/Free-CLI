  },
  "homepage": "https://github.com/Shadysmetools/knowcap-code#readme",
  "dependencies": {
    "@mermaid-js/mermaid-cli": "^11.12.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/inquirer": "^8.2.12",
    "axios": "^1.6.0",
    "better-sqlite3": "^12.8.0",
    "chalk": "^4.1.2",
