{
  "name": "coderaw",
  "version": "1.0.0",
  "description": "Free AI coding CLI — works with any model (Ollama, Groq, Gemini, OpenAI, Anthropic, OpenRouter)",
  "main": "dist/index.js",
  "bin": {
    "coderaw": "./dist/index.js",
    "cr": "./dist/index.js",
    "kcc": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc && node -e \"require('fs').cpSync('src/skills/builtins','dist/skills/builtins',{recursive:true})\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "coding",
    "assistant",
    "claude-code",
    "ollama",
    "groq",
    "mcp",
    "cli",
    "agent",
    "coderaw",
    "free"
  ],
  "author": "Shadysmetools",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Shadysmetools/Free-CLI.git"
  },
  "bugs": {
    "url": "https://github.com/Shadysmetools/Free-CLI/issues"
  },
  "homepage": "https://github.com/Shadysmetools/Free-CLI#readme",
  "dependencies": {
    "@mermaid-js/mermaid-cli": "^11.12.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/inquirer": "^8.2.12",
    "axios": "^1.6.0",
    "better-sqlite3": "^12.8.0",
    "chalk": "^4.1.2",
    "cli-highlight": "^2.1.11",
    "commander": "^12.0.0",
    "cors": "^2.8.6",
    "dotenv": "^16.4.0",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "glob": "^10.3.10",
    "grammy": "^1.42.0",
    "inquirer": "^8.2.6",
    "marked": "^12.0.0",
    "marked-terminal": "^7.0.0",
    "ora": "^5.4.1",
    "pdfkit": "^0.18.0",
    "sqlite-vec": "^0.1.9",
    "yaml": "^2.4.1"
  },
  "devDependencies": {
    "@types/inquirer": "^8.2.10",
