  "bin": {
    "knowcap-code": "./dist/index.js",
    "kcc": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc && cp -r src/skills/builtins dist/skills/",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "coding",
    "assistant",
    "claude-code",
    "ollama",
    "groq",
    "mcp",
    "cli",
    "agent"
  ],
  "author": "Shadysmetools",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Shadysmetools/knowcap-code.git"
  },
  "bugs": {
